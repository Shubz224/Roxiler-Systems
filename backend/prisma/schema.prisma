// This is your Prisma schema file
// It defines the database structure for the Store Rating Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(60)
  email     String   @unique
  password  String
  address   String   @db.VarChar(400)
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  ratings Rating[]
  store   Store? // only if role is STORE_OWNER
}

model Store {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(60)
  email     String   @unique
  address   String   @db.VarChar(400)
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   Int      @unique // one owner can have only one store
  createdAt DateTime @default(now())

  ratings Rating[]
}

model Rating {
  id        Int      @id @default(autoincrement())
  rating    Int // validated 1-5 in Joi schema
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  store     Store    @relation(fields: [storeId], references: [id])
  storeId   Int
  createdAt DateTime @default(now())

  @@unique([userId, storeId]) // one rating per user per store — enforced at DB level
}

enum Role {
  ADMIN
  USER
  STORE_OWNER
}
